FASTROUTER_API_KEY=

SCALEKIT_ENVIRONMENT_URL=
SCALEKIT_CLIENT_ID=
SCALEKIT_CLIENT_SECRET=
NOTION_CONNECTION_NAME=
GOOGLE_CALENDAR_CONNECTION_NAME=

# Optional. Doctor Mode real transcript source.
# Leave CARRY_TRANSCRIPT_SOURCE unset or set to simulator for the built-in demo.
# Set to websocket, then run npm run doctor:live:real to consume /v4/live/transcripts.
CARRY_TRANSCRIPT_SOURCE=simulator
CARRY_BACKEND_WS_URL=https://your-ngrok-url.ngrok-free.app
CARRY_WS_IDLE_MS=12000
CARRY_WS_MAX_MS=300000
